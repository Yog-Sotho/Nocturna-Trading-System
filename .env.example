# =============================================================================
# NOCTURNA Trading System - Environment Configuration
# =============================================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# NEVER COMMIT .env TO VERSION CONTROL
# =============================================================================

# =============================================================================
# SECURITY CONFIGURATION (REQUIRED)
# =============================================================================

# Flask Secret Key - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=your-flask-secret-key-here

# JWT Secret Key - Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-here

# Session Cookie Security
SECURE_COOKIES=true
SESSION_COOKIE_SAMESITE=Lax

# Allowed CORS Origins (comma-separated for multiple)
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# IP Whitelist/Blacklist (comma-separated, optional)
# IP_WHITELIST=192.168.1.1,10.0.0.0/8
# IP_BLACKLIST=192.168.1.100

# =============================================================================
# FLASK APPLICATION
# =============================================================================

FLASK_ENV=production
FLASK_DEBUG=false
HOST=0.0.0.0
PORT=5000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL (recommended for production)
DATABASE_URL=postgresql://nocturna:your-db-password@postgres:5432/nocturna

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================

REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password

# =============================================================================
# TRADING API KEYS (REQUIRED FOR LIVE TRADING)
# =============================================================================

# Alpaca Markets
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# For live trading: https://api.alpaca.markets

# Polygon.io
POLYGON_API_KEY=your-polygon-api-key

# =============================================================================
# TRADING PARAMETERS
# =============================================================================

# Trading Mode: PAPER or LIVE
TRADING_MODE=PAPER

# Initial Capital (USD)
INITIAL_CAPITAL=100000

# Maximum Position Size (fraction, e.g., 0.2 = 20%)
MAX_POSITION_SIZE=0.2

# Risk Level: LOW, MEDIUM, HIGH, AGGRESSIVE
RISK_LEVEL=LOW

# =============================================================================
# RISK MANAGEMENT
# =============================================================================

# Maximum Daily Loss (fraction)
MAX_DAILY_LOSS=0.05

# Maximum Drawdown (fraction)
DRAWDOWN_STOP=0.15

# Maximum Portfolio Risk per Trade (fraction)
MAX_PORTFOLIO_RISK=0.02

# =============================================================================
# STRATEGY PARAMETERS
# =============================================================================

UPDATE_INTERVAL=60
GRID_SPACING=0.005
ATR_MULT_SL=2.0
ATR_MULT_TP=4.0
VOLATILITY_THRESHOLD=2.0
TREND_STRENGTH_THRESHOLD=0.5

# =============================================================================
# LOGGING
# =============================================================================

LOG_LEVEL=INFO
LOG_FILE=/app/logs/nocturna.log
LOG_TO_FILE=true
LOG_TO_CONSOLE=true
AUDIT_LOG_FILE=/app/logs/audit.log

# =============================================================================
# MONITORING & ALERTING
# =============================================================================

# Sentry DSN (optional)
SENTRY_DSN=

# Prometheus Metrics
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=8000

# =============================================================================
# BACKUP & STORAGE
# =============================================================================

ENABLE_BACKUPS=true
BACKUP_FREQUENCY=daily
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# =============================================================================
# NOTIFICATIONS
# =============================================================================

ENABLE_NOTIFICATIONS=false

# Slack
SLACK_WEBHOOK_URL=

# Discord
DISCORD_WEBHOOK_URL=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
NOTIFICATION_PHONE_NUMBER=

# =============================================================================
# DEFAULT SYMBOLS
# =============================================================================

DEFAULT_SYMBOLS=SPY,QQQ,AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA

# =============================================================================
# ADMIN USER (Initial Setup)
# =============================================================================

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@yourdomain.com
# Generate password with: python -c "import secrets; print(secrets.token_urlsafe(16))"
ADMIN_PASSWORD=change-this-password-immediately

# =============================================================================
# FEATURE FLAGS
# =============================================================================

DISABLE_REGISTRATION=false
ENABLE_REGIME_DETECTION=true
ENABLE_MULTI_TIMEFRAME=true
ENABLE_PORTFOLIO_OPTIMIZATION=true
