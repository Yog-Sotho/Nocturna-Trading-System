# NOCTURNA v2.0 Trading Bot - Configuration Example
# Copy this file to .env and fill in your actual values

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================

# Initial capital for trading (USD)
INITIAL_CAPITAL=100000

# Maximum position size as percentage of portfolio (0.1 = 10%)
MAX_POSITION_SIZE=0.1

# Risk level: LOW, MEDIUM, HIGH, AGGRESSIVE
RISK_LEVEL=LOW

# Trading mode: PAPER or LIVE
TRADING_MODE=PAPER

# =============================================================================
# ALPACA TRADING API
# =============================================================================

# Alpaca API credentials
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Alpaca base URL
# Paper trading: https://paper-api.alpaca.markets
# Live trading: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# =============================================================================
# MARKET DATA PROVIDERS
# =============================================================================

# Polygon.io API key for real-time market data
POLYGON_API_KEY=your_polygon_api_key_here

# Alpha Vantage API key (alternative data source)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# IEX Cloud API key (alternative data source)
IEX_CLOUD_API_KEY=your_iex_cloud_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL
# SQLite (default): sqlite:///nocturna.db
# PostgreSQL: postgresql://user:password@localhost/nocturna
# MySQL: mysql://user:password@localhost/nocturna
DATABASE_URL=sqlite:///nocturna.db

# =============================================================================
# REDIS CONFIGURATION (Optional - for caching)
# =============================================================================

# Redis URL for caching and session storage
REDIS_URL=redis://localhost:6379/0

# Redis password (if required)
REDIS_PASSWORD=

# =============================================================================
# FLASK APPLICATION SETTINGS
# =============================================================================

# Flask environment: development, production
FLASK_ENV=development

# Flask debug mode: True, False
FLASK_DEBUG=True

# Secret key for Flask sessions (generate a random string)
FLASK_SECRET_KEY=your-super-secret-key-change-this-in-production

# Application host and port
HOST=0.0.0.0
PORT=5000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/nocturna.log

# Enable file logging: True, False
LOG_TO_FILE=True

# Enable console logging: True, False
LOG_TO_CONSOLE=True

# =============================================================================
# TRADING PARAMETERS
# =============================================================================

# Grid trading spacing as percentage (0.005 = 0.5%)
GRID_SPACING=0.005

# ATR multiplier for stop loss
ATR_MULT_SL=2.0

# ATR multiplier for take profit
ATR_MULT_TP=4.0

# Volatility threshold for mode switching
VOLATILITY_THRESHOLD=2.0

# Trend strength threshold (0.0 to 1.0)
TREND_STRENGTH_THRESHOLD=0.5

# Number of confirmation bars for reversal signals
REVERSAL_CONFIRMATION_BARS=3

# Volume multiplier for breakout confirmation
BREAKOUT_VOLUME_MULT=1.5

# =============================================================================
# RISK MANAGEMENT
# =============================================================================

# Maximum portfolio risk per trade (0.02 = 2%)
MAX_PORTFOLIO_RISK=0.02

# Maximum position risk per trade (0.005 = 0.5%)
MAX_POSITION_RISK=0.005

# Maximum correlation between positions
MAX_CORRELATION=0.7

# Maximum sector concentration (0.3 = 30%)
MAX_SECTOR_CONCENTRATION=0.3

# Daily loss limit as percentage of capital (0.01 = 1%)
DAILY_LOSS_LIMIT=0.01

# Drawdown stop level (0.1 = 10%)
DRAWDOWN_STOP=0.1

# =============================================================================
# MACHINE LEARNING CONFIGURATION
# =============================================================================

# ML optimization frequency: daily, weekly, monthly
ML_OPTIMIZATION_FREQUENCY=weekly

# Number of iterations for parameter optimization
ML_OPTIMIZATION_ITERATIONS=100

# Validation split for ML training (0.2 = 20%)
ML_VALIDATION_SPLIT=0.2

# Enable feature selection: True, False
ML_FEATURE_SELECTION=True

# ML models to use: rf (Random Forest), gb (Gradient Boosting), xgb (XGBoost)
ML_MODELS=rf,gb

# =============================================================================
# BACKTESTING CONFIGURATION
# =============================================================================

# Commission rate (0.001 = 0.1%)
COMMISSION_RATE=0.001

# Slippage rate (0.0005 = 0.05%)
SLIPPAGE_RATE=0.0005

# Minimum trade size (USD)
MIN_TRADE_SIZE=100

# Backtesting start date (YYYY-MM-DD)
BACKTEST_START_DATE=2020-01-01

# Backtesting end date (YYYY-MM-DD) - leave empty for current date
BACKTEST_END_DATE=

# =============================================================================
# SENTIMENT ANALYSIS
# =============================================================================

# Enable sentiment analysis: True, False
ENABLE_SENTIMENT_ANALYSIS=True

# News API key for sentiment analysis
NEWS_API_KEY=your_news_api_key_here

# Twitter API credentials (for social sentiment)
TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here

# Reddit API credentials (for social sentiment)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=NOCTURNA_v2_Bot

# =============================================================================
# NOTIFICATION SETTINGS
# =============================================================================

# Enable notifications: True, False
ENABLE_NOTIFICATIONS=False

# Email notifications
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
NOTIFICATION_EMAIL=your_notification_email@gmail.com

# Slack notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Discord notifications
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Twilio SMS notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
NOTIFICATION_PHONE_NUMBER=your_notification_phone_number_here

# =============================================================================
# MONITORING AND ALERTING
# =============================================================================

# Enable Prometheus metrics: True, False
ENABLE_PROMETHEUS=False

# Prometheus metrics port
PROMETHEUS_PORT=8000

# Sentry DSN for error tracking
SENTRY_DSN=your_sentry_dsn_here

# Enable performance monitoring: True, False
ENABLE_PERFORMANCE_MONITORING=True

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# JWT secret key for API authentication
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# JWT token expiration time (hours)
JWT_EXPIRATION_HOURS=24

# Enable API rate limiting: True, False
ENABLE_RATE_LIMITING=True

# API rate limit (requests per minute)
API_RATE_LIMIT=100

# =============================================================================
# BACKUP AND RECOVERY
# =============================================================================

# Enable automatic backups: True, False
ENABLE_BACKUPS=True

# Backup frequency: hourly, daily, weekly
BACKUP_FREQUENCY=daily

# Backup retention days
BACKUP_RETENTION_DAYS=30

# AWS S3 backup configuration (optional)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=your-backup-bucket-name
AWS_REGION=us-east-1

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Enable debug mode: True, False
DEBUG_MODE=False

# Enable profiling: True, False
ENABLE_PROFILING=False

# Mock trading (for testing without real API calls): True, False
MOCK_TRADING=False

# Simulation speed multiplier (for faster backtesting)
SIMULATION_SPEED=1.0

# =============================================================================
# ADVANCED FEATURES
# =============================================================================

# Enable multi-timeframe analysis: True, False
ENABLE_MULTI_TIMEFRAME=True

# Enable options trading: True, False (requires additional setup)
ENABLE_OPTIONS_TRADING=False

# Enable crypto trading: True, False (requires additional setup)
ENABLE_CRYPTO_TRADING=False

# Enable forex trading: True, False (requires additional setup)
ENABLE_FOREX_TRADING=False

# Enable portfolio optimization: True, False
ENABLE_PORTFOLIO_OPTIMIZATION=True

# Enable regime detection: True, False
ENABLE_REGIME_DETECTION=True

# =============================================================================
# SYMBOLS AND MARKETS
# =============================================================================

# Default symbols to trade (comma-separated)
DEFAULT_SYMBOLS=SPY,QQQ,AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA

# Market hours (Eastern Time)
MARKET_OPEN_TIME=09:30
MARKET_CLOSE_TIME=16:00

# Enable pre-market trading: True, False
ENABLE_PREMARKET=False

# Enable after-hours trading: True, False
ENABLE_AFTERHOURS=False

# =============================================================================
# PERFORMANCE OPTIMIZATION
# =============================================================================

# Number of worker threads
WORKER_THREADS=4

# Enable multiprocessing: True, False
ENABLE_MULTIPROCESSING=True

# Cache timeout (seconds)
CACHE_TIMEOUT=300

# Enable data compression: True, False
ENABLE_DATA_COMPRESSION=True

# Maximum memory usage (MB)
MAX_MEMORY_USAGE=2048

